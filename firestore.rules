rules_version = '2';
// ================================================================
// Firestore Security Rules for ChatApp
// Deploy with: firebase deploy --only firestore:rules
// ================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isMember(chatData) {
      return request.auth.uid in chatData.members;
    }

    function isAdmin(chatData) {
      return request.auth.uid in chatData.admins;
    }

    // ── Users ─────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false; // No deleting accounts via client
    }

    // ── OTP Codes (server-managed, deny all client access) ───────
    match /otpCodes/{email} {
      allow read, write: if false; // Only server-side API routes access this
    }

    // ── Chats ─────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.members;
      allow update: if isSignedIn() && isMember(resource.data);
      allow delete: if false;

      // ── Messages ──────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isSignedIn() && isMember(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/chats/$(chatId)).data)
          && request.resource.data.senderId == request.auth.uid;
        allow update: if isSignedIn()
          && isMember(get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow delete: if false;
      }
    }
  }
}
